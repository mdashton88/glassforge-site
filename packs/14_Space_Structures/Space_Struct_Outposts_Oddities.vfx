{
  "id": "space-struct-outposts-oddities",
  "name": "Space Structures \u2014 Outposts & Oddities",
  "version": "1.0",
  "publisher": "DiceForge Studios Ltd.",
  "description": "10 structures \u2014 The strange, the abandoned, and the dangerous. Research stations on the edge of known space, derelict megastructures drifting in the dark, pirate havens hidden in asteroid fields, and alien constructs that defy human understanding.",
  "weapons": [],
  "mods": [],
  "specials": [],
  "vehicles": [
    {
      "name": "Remote Research Station",
      "desc": "Small scientific outpost positioned at the edge of known space, studying phenomena that larger institutions don't want too close to populated systems. Crew of thirty living in cramped modules, months from the nearest help, conducting experiments that require isolation for reasons the grant applications describe as 'safety considerations.' The previous crew left in a hurry. The logs explain why, if you can find the password.",
      "notes": "Isolated horror scenario. Isolated. Small crew. Something has gone wrong.",
      "size": 10,
      "loco": "none",
      "toughLevel": -1,
      "armourLevel": 0,
      "speedLevel": 0,
      "handlingLevel": 0,
      "woundsLevel": 0,
      "crewLevel": 0,
      "passengers": 0,
      "mphOverride": 0,
      "mods": {},
