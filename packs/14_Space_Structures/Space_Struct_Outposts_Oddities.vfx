        {
          "weaponId": "laser_gat",
          "mount": "turret",
          "linked": 0
        }
      ]
    },
    {
      "name": "Derelict Hulk",
      "desc": "Dead megastructure drifting through the void on a trajectory that suggests she was abandoned \u2014 or killed \u2014 centuries ago. Power systems are cold. Atmosphere has leaked from a thousand micro-breaches. Her corridors are dark, frozen, and littered with the debris of whatever happened here. Salvage teams approach with caution and leave with nightmares. She's worth a fortune in recoverable materials. Nobody has successfully claimed it yet.",
      "notes": "Abandoned wreck. No power. No atmosphere. Dangerous to explore. Valuable salvage.",
      "size": 24,
      "loco": "none",
      "toughLevel": 1,
      "armourLevel": 0,
      "speedLevel": 0,
      "handlingLevel": 0,
      "woundsLevel": 0,
      "crewLevel": 0,
      "passengers": 0,
      "mphOverride": 0,
      "mods": {},
      "weapons": []
    },
    {
      "name": "Pirate Haven",
      "desc": "Hidden station built into an asteroid field, invisible to casual sensor sweeps and accessible only through a navigation route known to those the pirates trust \u2014 which is nobody, but some people they distrust less than others. Docking bays accommodate stolen vessels, the marketplace trades in contraband, and the bar serves drinks that would dissolve hull plating. Law enforcement knows she exists. Finding her is another matter entirely.",
      "notes": "Tortuga in space. Hidden location. Black market. No law. No rules. No refunds.",
      "size": 14,
      "loco": "none",
      "toughLevel": 1,
      "armourLevel": 1,
      "speedLevel": 0,
      "handlingLevel": 0,
      "woundsLevel": 0,
      "crewLevel": -9,
      "passengers": 0,
      "mphOverride": 0,
      "mods": {},
