          "linked": 0
        }
      ]
    },
    {
      "name": "Space Elevator Terminal",
      "desc": "Orbital anchor point for a tether connecting a planet's surface to geostationary orbit. Cargo pods climb the tether at a fraction of the cost of rocket launch, and the terminal at the top is a bustling transfer hub where ground-to-orbit freight meets interplanetary shipping. She's the most important piece of infrastructure on the planet \u2014 the bottleneck through which everything passes. Control the elevator and you control the world below.",
      "notes": "Ground-to-orbit infrastructure. Critical chokepoint. Massive cargo throughput. Strategic.",
      "size": 20,
      "loco": "none",
      "toughLevel": 1,
      "armourLevel": 0,
      "speedLevel": 0,
      "handlingLevel": 0,
      "woundsLevel": 0,
      "crewLevel": 180,
      "passengers": 0,
      "mphOverride": 0,
      "mods": {},
