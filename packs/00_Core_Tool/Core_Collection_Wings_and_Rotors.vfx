{
  "id": "core-wings-rotors",
  "name": "Core Collection \u2014 Wings & Rotors",
  "version": "1.0",
  "publisher": "DiceForge Studios Ltd.",
  "description": "15 vehicles \u2014 Aircraft from canvas biplanes to modern strike fighters. Reference implementations from the Savage Worlds core rules covering propeller, jet, and rotary-wing flight.",
  "weapons": [],
  "mods": [],
  "specials": [],
  "vehicles": [
    {
      "name": "Civilian Biplane",
      "size": 4,
      "loco": "turboprop",
      "desc": "Open cockpit, fabric wings, a romantic way to die. Barnstormers, crop dusters, and Tiger Moths.",
      "notes": "Tiger Moths, Sopwith Pups, Stearman PT-17s, de Havilland Gipsy Moths, and every barnstormer that ever terrified a county fair. Open cockpit, fabric over wood and wire, and a top speed that lets passengers appreciate the scenery whether they want to or not. She's your inter-war and pulp adventure aircraft \u2014 slow enough for pistol fights from the cockpit, low enough to barnstorm, fragile enough that every bullet matters. Wind in your face, oil on your goggles, and the ground uncomfortably close.",
      "toughLevel": 1,
      "armourLevel": -2,
      "speedLevel": -2,
      "handlingLevel": 1,
      "woundsLevel": -2,
      "mods": {},
      "weapons": [],
      "specials": [
        "open_top",
        "short_range"
      ],
      "customSpecial": "",
      "mphOverride": 125
    },
    {
      "name": "Light Civilian Aircraft",
      "size": 5,
      "loco": "turboprop",
      "desc": "Single-engine four-seater. Cessnas, Pipers, and Beechcrafts \u2014 the most common aircraft in the sky.",
      "notes": "Cessna 172 Skyhawks, Piper Cherokees, Beechcraft Bonanzas, and their hundreds of variants. The most common aircraft type in the sky. She's the plane your players charter, steal, or escape in \u2014 simple to fly, cheap to hire, and she lands on dirt strips that would destroy anything bigger. Also covers bush planes, survey aircraft, and the small charter services that connect remote locations to civilisation.",
      "toughLevel": 0,
      "armourLevel": -1,
      "speedLevel": -2,
      "handlingLevel": 1,
      "woundsLevel": -2,
      "mods": {},
      "weapons": [],
      "specials": [
        "enclosed"
      ],
      "customSpecial": "",
      "passengers": 3,
      "mphOverride": 140
    },
    {
      "name": "Civilian Helicopter",
      "size": 7,
      "loco": "vtol",
      "desc": "General-purpose rotorcraft. Bell 206s, Robinson R44s \u2014 news, medevac, tourism, escape.",
      "notes": "Bell 206 JetRangers, Robinson R44s, Eurocopter EC135s, and the hundreds of civilian rotorcraft types used for news coverage, executive transport, medevac, law enforcement, and tourism. Her unique ability is hover and vertical landing \u2014 she doesn't need a runway. Use her for dramatic rooftop extractions, medical evacuations, and the moment the players realise that the villain's escape plan doesn't involve roads. VTOL.",
      "toughLevel": -1,
      "armourLevel": -1,
      "speedLevel": -1,
      "handlingLevel": 0,
      "woundsLevel": -2,
      "mods": {},
      "weapons": [],
      "specials": [
        "enclosed",
        "stol"
      ],
      "customSpecial": "",
      "passengers": 3,
      "mphOverride": 130
    },
    {
      "name": "Executive Jet",
      "size": 8,
      "loco": "jet",
      "desc": "Fast, comfortable, and proof that someone is doing well. Learjets, Gulfstreams, Citations.",
      "notes": "Learjet 45s, Gulfstream IVs, Cessna Citations, Bombardier Challengers, and every private aircraft that costs more than most houses. She gets people across continents in hours, and her presence at an airstrip tells you everything about the owner \u2014 money, connections, urgency. She's also a beautiful target sitting unguarded on a remote runway at three in the morning.",
      "armourLevel": -1,
      "speedLevel": -1,
      "handlingLevel": 3,
      "woundsLevel": -2,
      "mods": {},
      "weapons": [],
      "specials": [
        "enclosed",
        "spacious",
        "long_range"
      ],
      "customSpecial": "",
      "crewLevel": -3,
      "passengers": 10,
      "mphOverride": 540
    },
    {
      "name": "Space Shuttle",
      "size": 13,
      "loco": "jet",
      "desc": "Reusable orbital vehicle. Three main engines, two solid boosters, one fragile heat shield.",
      "notes": "The NASA Space Shuttle, Buran, and their fictional successors. She demonstrates that size and Toughness don't always correlate with combat power \u2014 the shuttle is enormous but fragile, a precision instrument designed for a specific mission rather than a fight. Use her as a reference point for near-future and hard sci-fi campaigns where getting to orbit is still dangerous and expensive.",
      "armourLevel": -1,
      "speedLevel": 5,
      "handlingLevel": 1,
      "mods": {},
      "weapons": [],
      "specials": [
        "enclosed",
        "sealed",
        "pressurised"
      ],
      "customSpecial": "",
      "crewLevel": -19,
      "passengers": 40,
      "mphOverride": 17000
    },
    {
      "name": "WW2 Fighter (Allied, Early-War)",
      "size": 6,
      "loco": "turboprop",
      "desc": "Eight machine guns, elliptical wings, and the Battle of Britain. Spitfires, Hurricanes, and P-40s.",
      "notes": "Supermarine Spitfires (Mk I through V), Hawker Hurricanes, Curtiss P-40 Warhawks, Grumman F4F Wildcats, and the other Allied fighters that held the line before the war turned. The Spitfire and Hurricane split the Battle of Britain between them \u2014 Hurricanes took the bombers, Spitfires took the escorts. The P-40 fought in every theatre from North Africa to China. These aircraft weren't always the fastest or best-armed, but they were there when it mattered and the pilots who flew them refused to lose.",
      "toughLevel": 1,
      "armourLevel": -2,
      "speedLevel": -1,
      "handlingLevel": 1,
      "mods": {},
      "weapons": [
