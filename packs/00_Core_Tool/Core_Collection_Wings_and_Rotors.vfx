      "mphOverride": 350
    },
    {
      "name": "WW2 Heavy Bomber",
      "size": 10,
      "loco": "turboprop",
      "desc": "Four engines, ten crew, bristling with defensive guns. B-17s, Lancasters, and He-111s \u2014 strategic bombing incarnate.",
      "notes": "B-17 Flying Fortresses, B-24 Liberators, Avro Lancasters, Halifax bombers, He-111s, and the other strategic bombers that brought the war to the enemy's homeland. Ten crew, defensive guns at every angle, and hours of straight-and-level flying through flak corridors and fighter screens. Every mission is a survival horror session at 25,000 feet. Use her for crew-based scenarios where every position matters and a single engine fire can kill everyone aboard.",
      "toughLevel": 0,
      "armourLevel": -1,
      "speedLevel": -4,
      "handlingLevel": -1,
      "mods": {},
