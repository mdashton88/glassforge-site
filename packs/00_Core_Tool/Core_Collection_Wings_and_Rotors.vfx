      "mphOverride": 225
    },
    {
      "name": "VTOL Strike Fighter",
      "size": 7,
      "loco": "vtol",
      "desc": "Vertical takeoff, subsonic, ground attack specialist. Harriers, Yak-38s, and their successors.",
      "notes": "AV-8B Harrier IIs, Sea Harriers, Yak-38 Forgers, and their successor concepts. She operates from roads, forest clearings, and amphibious ships too small for conventional aircraft. VTOL capability means close air support can stage from positions the enemy doesn't expect \u2014 and recover to locations they can't find. Slower than conventional jets, but she doesn't need a runway, and that changes everything. VTOL.",
      "speedLevel": 3,
      "handlingLevel": 1,
