      "mphOverride": 380
    },
    {
      "name": "WW2 Fighter (Pacific)",
      "size": 6,
      "loco": "turboprop",
      "desc": "Exceptional range and manoeuvrability, paid for with zero armour protection. Zeros, Oscars, and their kin.",
      "notes": "Mitsubishi A6M Zeros, Nakajima Ki-43 Oscars, Ki-84 Hayates, and the other Japanese fighters that traded protection for performance. Exceptional range and manoeuvrability, paid for with minimal armour and no self-sealing fuel tanks. A Zero could outmanoeuvre anything the Allies flew in 1942 \u2014 but one burst of .50 calibre could set her on fire. The ultimate glass cannon. Use her to show players that the best dogfighter in the sky can still die to a single lucky hit.",
      "armourLevel": -1,
      "speedLevel": -1,
      "handlingLevel": 1,
      "mods": {},
      "weapons": [
        {
          "weaponId": "mmg",
          "mount": "fixed",
