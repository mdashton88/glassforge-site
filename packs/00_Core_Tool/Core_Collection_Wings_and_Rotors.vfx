      "mphOverride": 120
    },
    {
      "name": "Modern Attack Helicopter",
      "size": 8,
      "loco": "vtol",
      "desc": "Tandem cockpit, chain gun, guided missiles. Apaches, Hinds, and Tigers \u2014 the apex predators.",
      "notes": "AH-64 Apaches in all their variants, Mi-24 Hinds, Mi-28 Havocs, Eurocopter Tigers, Mangusta A129s, and Kamov Ka-52 Alligators. Tandem cockpit, sensor suite, guided missiles, and an autocannon or chain gun that follows the gunner's helmet. She finds targets, kills them at range, and relocates before ground fire can respond. The Hind pioneered the concept, the Apache perfected it. Use her to demonstrate the terrifying capability gap between infantry and modern air power. Helicopter, Night Vision.",
      "toughLevel": 1,
      "armourLevel": -1,
      "speedLevel": 0,
      "handlingLevel": 1,
      "mods": {},
      "weapons": [
        {
          "weaponId": "autocannon_30mm",
