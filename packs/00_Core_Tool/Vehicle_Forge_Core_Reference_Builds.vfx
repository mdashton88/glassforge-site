    {
      "name": "Hover APC (SWADE)",
      "size": 7,
      "loco": "hover",
      "toughLevel": 1,
      "armourLevel": -1,
      "speedLevel": 2,
      "desc": "Troop transport on a hover chassis. She carries a squad across any terrain at speed, including water, and mounts a defensive weapon system that keeps heads down during the approach. The infantry dismount directly into whatever hellscape the APC just glided across.",
      "notes": "The hover APC delivers troops across any terrain at speed. She's the future of mechanised infantry — rivers, rubble, swamp, and rough ground are no longer obstacles. Heavy Armor, Hover.",
      "weapons": [
        {
          "weaponId": "laser_gat",
          "mount": "fixed",
          "linked": 0
        }
      ],
      "mods": {},
