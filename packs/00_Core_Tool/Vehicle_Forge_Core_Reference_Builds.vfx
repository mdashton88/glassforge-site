{
  "id": "core-reference-builds",
  "name": "SWADE Core Reference Builds",
  "version": "2.0",
  "publisher": "DiceForge Studios",
  "description": "47 vehicles from the Savage Worlds core rulebook (pp.83-85), calibrated against canon stat lines. Weapons match SWADE vehicular weapons table (pp.80-81).",
  "price": "Free",
  "weapons": [],
  "mods": [],
  "specials": [],
  "vehicles": [
    {
      "name": "Bicycle",
      "size": -1,
      "loco": "wheeled",
      "armourLevel": -1,
      "desc": "Two wheels, no engine, and the most efficient transport ever invented. She goes where cars can\\'t, makes no noise, and nobody looks twice at a cyclist.",
      "notes": "The bicycle is invisible. Nobody notices one more cyclist on a city street, which makes it the perfect surveillance and courier vehicle for low-tech campaigns. In chase scenes, she squeezes through gaps no car can follow — alleys, stairwells, crowded markets. 50% of shots hit the rider rather than the vehicle.",
      "weapons": [],
      "mods": {},
      "specials": [
        "open_top"
      ],
      "_pack": "core"
    },
    {
      "name": "Carriage",
      "size": 3,
      "loco": "wheeled",
      "toughLevel": -1,
      "armourLevel": -3,
      "handlingLevel": -3,
      "speedLevel": -2,
      "desc": "Horse-drawn, four-wheeled, and the standard of overland travel for centuries. Speed depends entirely on the draft animals — a pair of carriage horses manages a comfortable trot, a post team at full gallop will shake your teeth loose.",
      "notes": "The carriage is your chase vehicle for historical and fantasy campaigns. Stagecoach robberies, runaway horses, rooftop leaps onto the luggage rack — she exists to create cinematic moments. Horse-drawn, so she stops when the horses do.",
      "weapons": [],
      "mods": {},
      "specials": [
        "open_top",
        "towing"
      ],
      "_pack": "core"
    },
    {
      "name": "Early Car",
      "size": 3,
      "loco": "wheeled",
      "armourLevel": -3,
      "handlingLevel": -2,
      "speedLevel": -1,
      "desc": "Twenty horsepower, a top speed of forty-five miles an hour, and a hand-crank starter that will break your arm if you're not careful. She rattles, she stalls on hills, and she changed the world. Every car that followed owes something to this one.",
      "notes": "The Model T generation. Slow, temperamental, and revolutionary. She puts your campaign on wheels for the first time — Prohibition rum-runners, early pulp adventures, the first getaway cars. Unreliable enough to create complications at the worst possible moment.",
      "weapons": [],
      "mods": {},
      "specials": [
        "enclosed",
        "temperamental"
      ],
      "_pack": "core"
    },
    {
      "name": "Street Bike",
      "size": 1,
      "loco": "wheeled",
      "toughLevel": 2,
      "armourLevel": -2,
      "speedLevel": 2,
      "desc": "Stock street motorcycle. Two wheels, one engine, no protection whatsoever. Fast enough to weave through traffic, light enough to lane-split, and the rider is completely exposed to everything from bullets to bad weather.",
      "notes": "The street bike is your urban pursuit vehicle. She splits lanes, she threads traffic, she fits where cars can't follow. The rider is exposed — 50% of shots hit them rather than the bike. That vulnerability is the price of agility.",
      "weapons": [],
      "mods": {},
      "specials": [
        "open_top"
      ],
      "_pack": "core"
    },
    {
      "name": "Dirt Bike",
      "size": 0,
      "loco": "wheeled",
      "toughLevel": 2,
      "armourLevel": -2,
      "speedLevel": 1,
      "desc": "Off-road motorcycle. Knobby tyres, long-travel suspension, and the ability to go anywhere a goat can go. She's lighter than the street bike, slower on tarmac, and infinitely more useful when the road ends.",
      "notes": "The dirt bike goes where roads don't. She's the jungle recon vehicle, the desert patrol bike, the mountain courier. Four-wheel drive equivalent for two wheels — she ignores terrain that stops wheeled vehicles cold.",
      "weapons": [],
      "mods": {
        "offroad": 1
      },
      "specials": [
        "open_top",
        "all_terrain"
      ],
      "_pack": "core"
    },
    {
      "name": "Compact Car",
      "size": 4,
      "loco": "wheeled",
      "armourLevel": -1,
      "handlingLevel": 1,
      "speedLevel": 1,
      "desc": "A Honda Civic or similar daily driver. Reliable, fuel-efficient, and completely unremarkable. Nobody looks twice at a compact car, which is exactly why they're the vehicle of choice for anyone who doesn't want to be noticed.",
      "notes": "The compact car is your default civilian vehicle. Every NPC drives one, every parking lot is full of them, every car chase starts or ends with one. Mechanically unremarkable, which is exactly the point — she's the baseline everything else is measured against.",
      "weapons": [],
      "mods": {},
      "specials": [
        "enclosed"
      ],
      "_pack": "core"
    },
    {
      "name": "Mid-Sized Car",
      "size": 4,
      "loco": "wheeled",
      "armourLevel": -1,
      "speedLevel": 1,
      "desc": "Air bags, cruise control, and enough legroom for adults in the back seat. The mid-sized sedan is the car that most people actually drive — comfortable enough for a road trip, anonymous enough for a stakeout.",
      "notes": "The family sedan. She carries more passengers and gear than the compact, handles roughly the same, and blends into traffic just as easily. The car your players borrow, steal, or commandeer when they need to move without attracting attention.",
      "weapons": [],
      "mods": {},
      "specials": [
        "enclosed",
        "cargo_bay"
      ],
      "_pack": "core"
    },
    {
      "name": "Minivan",
      "size": 4,
      "loco": "wheeled",
      "armourLevel": -1,
      "desc": "The family troop transport. Sliding doors, seven seats, and a cargo area that swallows luggage, equipment, and the occasional body. She's not fast, she's not cool, and she carries more people than anything else in the parking lot.",
      "notes": "The minivan carries a full party plus gear. She's the team vehicle for modern campaigns — the thing everyone piles into when the job starts. Not fast, not tough, but she holds everyone and their equipment in one vehicle.",
      "weapons": [],
      "mods": {},
      "specials": [
        "enclosed",
        "cargo_bay"
      ],
      "_pack": "core"
    },
    {
      "name": "SUV",
      "size": 5,
      "loco": "wheeled",
      "armourLevel": -1,
      "speedLevel": 1,
      "desc": "Four-wheel drive, raised suspension, and the illusion of ruggedness. Most SUVs never leave the tarmac, but the ones that do can handle dirt roads, shallow fords, and light off-road terrain without complaint.",
      "notes": "The SUV bridges civilian comfort and rough terrain capability. Four-wheel drive gets her off-road where sedans can't follow. She's the vehicle of choice for private security, rural law enforcement, and players who expect trouble outside city limits.",
      "weapons": [],
      "mods": {
        "offroad": 1
      },
      "specials": [
        "enclosed",
        "four_wd",
        "all_terrain"
      ],
      "_pack": "core"
    },
    {
      "name": "Sports Car",
      "size": 4,
      "loco": "wheeled",
      "armourLevel": -1,
      "handlingLevel": 2,
      "speedLevel": 3,
      "desc": "A Mustang or similar muscle car. More engine than the chassis strictly needs, louder than the neighbours would like, and fast enough to outrun most things on four wheels. She's not practical. She's not supposed to be.",
      "notes": "The sports car wins chases through speed and handling. She's fast on straights, nimble in corners, and utterly useless off-road or in bad weather. The vehicle your players lust after and the one that gets them into trouble.",
      "weapons": [],
      "mods": {},
      "specials": [
        "enclosed"
      ],
      "_pack": "core"
    },
    {
      "name": "Semi-Truck",
      "size": 9,
      "loco": "wheeled",
      "toughLevel": -1,
      "armourLevel": -4,
      "handlingLevel": 1,
      "speedLevel": -1,
      "desc": "Eighteen wheels and a diesel engine the size of a bathtub. With trailer she's seventy feet long, weighs forty tons, and takes a quarter mile to stop from highway speed. She carries everything civilisation needs from factory to shop. Without her, the economy stops.",
      "notes": "The semi-truck is your convoy centrepiece and your roadblock. She can't manoeuvre, she can't hide, and she takes a long time to stop. But she carries anything, tows anything, and at highway speed she's an unstoppable battering ram. Trailer: Size 7, Toughness 14(2).",
      "weapons": [],
      "mods": {},
      "specials": [
        "enclosed",
        "cargo_bay",
        "towing",
        "loud"
      ],
      "_pack": "core"
    },
    {
      "name": "WW2 Jeep",
      "size": 4,
      "loco": "wheeled",
      "armourLevel": -1,
      "handlingLevel": 1,
      "desc": "Four-wheel drive, canvas top, and room for four soldiers and their gear. The Jeep went everywhere the war went — North Africa, Normandy, the Pacific, the Italian mountains. She's tough, simple, and fixable with a wrench and determination.",
      "notes": "The jeep goes everywhere and carries everything. She's the workhorse of military campaigns from WWII to Vietnam — reconnaissance, command vehicle, ambulance, weapons platform. Open-topped and lightly armoured, which means the crew is always one burst away from disaster. Four-wheel drive.",
      "weapons": [
        {
          "weaponId": "mmg",
          "mount": "pintle",
          "linked": 0
        }
      ],
      "mods": {
        "offroad": 1
      },
      "specials": [
        "heavy_armor",
        "open_top",
        "four_wd"
      ],
      "_pack": "core"
    },
    {
      "name": "M4 Sherman",
      "size": 8,
      "loco": "tracked",
      "toughLevel": 1,
      "armourLevel": -3,
      "desc": "The workhorse of the Allied war effort. Reliable, numerous, and undergunned against late-war German armour — but she won through sheer numbers and mechanical dependability. If one broke down, another was right behind her.",
      "notes": "The workhorse of the Allied armoured forces. She wasn't the best tank of the war — the Germans outgunned her routinely — but there were always more Shermans. Use her as the reliable, available option that wins through numbers and logistics rather than individual superiority. Heavy Armor, Tracked.",
      "weapons": [
        {
          "weaponId": "tank_gun_75mm",
          "mount": "turret",
          "linked": 0
        },
        {
          "weaponId": "mmg",
          "mount": "fixed",
          "linked": 0
        },
        {
