    },
    {
      "name": "Biplane (Civilian)",
      "size": 4,
      "loco": "turboprop",
      "toughLevel": 1,
      "armourLevel": -1,
      "handlingLevel": 1,
      "speedLevel": -2,
      "desc": "Two wings, an open cockpit, and the wind in your face at a hundred miles an hour. She's slow by modern standards but capable of aerobatics that would tear a modern fighter apart. Barnstormers, crop dusters, and Great War aces all flew something like this.",
      "notes": "The biplane is your inter-war and pulp adventure aircraft. She's slow enough that the players can shoot pistols from the cockpit, low enough to barnstorm, and fragile enough that every bullet matters. Open cockpit, wind in your face, goggles and scarves.",
      "weapons": [],
      "mods": {},
      "specials": [
        "open_top",
        "short_range"
      ],
      "_pack": "core"
    },
    {
      "name": "Cessna Skyhawk",
      "size": 5,
      "loco": "turboprop",
      "armourLevel": -1,
      "handlingLevel": 1,
      "speedLevel": -2,
      "desc": "The most popular single-engine aircraft ever built. Four seats, a cruising speed of a hundred and twenty knots, and the ability to land on any reasonably flat strip of ground. Every flight school, bush pilot, and weekend aviator knows the Cessna.",
      "notes": "The Cessna is your civilian light aircraft. She's the plane the players charter, steal, or escape in. Simple to fly, cheap to hire, and she lands on dirt strips that would destroy anything bigger. The most produced aircraft in history for a reason.",
      "weapons": [],
      "mods": {},
      "specials": [
        "enclosed"
      ],
      "_pack": "core"
    },
    {
      "name": "Helicopter (Civilian)",
      "size": 7,
      "loco": "vtol",
      "toughLevel": -1,
      "armourLevel": -2,
      "speedLevel": -1,
      "desc": "Cargo and troop helicopter. She carries a squad, their equipment, and enough supplies for a short deployment. She lands in clearings, rooftops, and anywhere else flat enough to fit her rotors.",
      "notes": "The civilian helicopter's unique ability is hover and vertical landing. She doesn't need a runway. Use her for medical evacuation, news coverage, executive transport, and dramatic rooftop extractions. VTOL.",
      "weapons": [],
      "mods": {},
      "specials": [
        "enclosed",
        "stol"
      ],
      "_pack": "core"
    },
    {
      "name": "Learjet",
      "size": 8,
      "loco": "jet",
      "toughLevel": 1,
      "armourLevel": -3,
      "handlingLevel": 3,
      "speedLevel": -1,
      "desc": "Private business jet. She seats eight in leather comfort, cruises at five hundred miles an hour, and lands at airports that commercial airliners can't reach. The aircraft of choice for executives, celebrities, and anyone fleeing the country in a hurry.",
      "notes": "The Learjet is your fast long-range transport. She gets the players across continents in hours, and her presence tells them something about whoever owns it — money, connections, urgency. She's also a beautiful target sitting on a runway.",
      "weapons": [],
      "mods": {},
      "specials": [
        "enclosed",
        "spacious",
        "long_range"
      ],
      "_pack": "core"
    },
    {
      "name": "Space Shuttle",
      "size": 13,
      "loco": "jet",
      "toughLevel": -1,
      "armourLevel": -2,
      "handlingLevel": 1,
      "speedLevel": 5,
      "desc": "Orbital re-entry vehicle. She launches vertically on rocket boosters, operates in low Earth orbit, and glides home unpowered to a runway landing. The most complex vehicle ever built by human hands.",
      "notes": "The shuttle is your near-future and hard sci-fi reference point. She demonstrates that size and Toughness don't always correlate with combat power — the shuttle is large but fragile, designed for a specific mission rather than a fight.",
      "weapons": [],
      "mods": {},
      "specials": [
        "enclosed",
        "sealed",
        "pressurised"
      ],
      "_pack": "core"
    },
