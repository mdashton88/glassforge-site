    {
      "name": "Bf-109",
      "size": 6,
      "loco": "turboprop",
      "armourLevel": -1,
      "handlingLevel": 1,
      "speedLevel": -1,
      "desc": "Germany's frontline fighter from the first day of the war to the last. Fast, well-armed, and flown by some of the highest-scoring aces in history. Her narrow undercarriage made her a terror on landing, but in the air she was lethal.",
      "notes": "The Messerschmitt is Germany's primary fighter across the entire war. She's fast, she climbs well, and her cannon armament hits hard. The opposition your players face in every European air combat scenario from the Battle of Britain to Berlin.",
      "weapons": [
        {
          "weaponId": "cannon_20mm",
          "mount": "fixed",
          "linked": 0
