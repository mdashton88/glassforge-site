    {
      "name": "Hydrofoil",
      "size": 10,
      "loco": "water_turbo",
      "desc": "Foil-borne at speed, hull-borne at rest. Fast and smooth in calm water, miserable in rough.",
      "notes": "Boeing Jetfoils, Soviet Kometa class, Rodriquez RHS series, and military hydrofoils like the Pegasus class. She lifts out of the water on submerged foils at speed, dramatically reducing drag. Fast and smooth in calm water, increasingly uncomfortable as seas build. Your fast coastal patrol and intercept vessel \u2014 faster than conventional boats, more agile, and harder to hit when she's foil-borne.",
      "toughLevel": -1,
      "armourLevel": -1,
      "speedLevel": 2,
      "handlingLevel": 1,
      "mods": {},
      "weapons": [],
      "specials": [
        "enclosed"
      ],
      "customSpecial": "",
      "crewLevel": -4,
      "passengers": 9,
      "mphOverride": 70
    },
    {
      "name": "Ancient War Galley",
      "size": 13,
      "loco": "water_sail",
      "desc": "Oars and sails. Triremes, biremes, and dromons \u2014 ram the enemy, board the wreckage.",
      "notes": "Greek triremes, Roman quinqueremes, Byzantine dromons, Carthaginian war galleys, and Viking longships at the larger end. Oars give her independence from wind \u2014 she moves when and where the captain commands, which made galleys the dominant naval platform from Salamis to Lepanto. Her ram is as dangerous as her mounted weapons, and boarding actions were the decisive tactic of ancient naval warfare. Heavy Armor, Oars+Sails.",
      "armourLevel": -1,
      "speedLevel": 0,
      "handlingLevel": 1,
      "mods": {},
      "weapons": [
        {
          "weaponId": "ballista",
          "mount": "fixed",
          "linked": 0
        }
      ],
      "specials": [
        "heavy_armor",
        "enclosed",
        "ram_plate"
      ],
      "customSpecial": "",
      "passengers": 100,
      "mphOverride": 20
    },
    {
      "name": "Age of Sail Warship",
      "size": 14,
      "loco": "water_sail",
      "desc": "Three masts, multiple gun decks, the capital ship of the age of sail. Galleons, men-o-war, and ships of the line.",
      "notes": "Spanish galleons, English men-o-war, French ships of the line, Dutch East Indiamen, and every three-masted warship that ruled the seas from the 16th to 19th centuries. Multiple gun decks, crews of hundreds, and enough provisions for months at sea. She's a floating fortress, a mobile settlement, and the centrepiece of your pirate or Napoleonic campaign. Broadside combat is her purpose \u2014 she doesn't chase, she dominates the space she occupies. Heavy Armor.",
      "toughLevel": -1,
      "armourLevel": -1,
      "speedLevel": -1,
