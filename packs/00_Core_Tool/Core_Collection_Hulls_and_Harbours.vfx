      "mphOverride": 32
    },
    {
      "name": "WW2 Torpedo Boat",
      "size": 12,
      "loco": "water_turbo",
      "desc": "Fast, wooden, expendable. PT boats, E-boats, and MTBs \u2014 torpedo runs under fire.",
      "notes": "American PT boats, British MTBs (Motor Torpedo Boats), German E-boats (Schnellboote), Italian MAS boats, and Japanese torpedo craft. Fast, wooden-hulled, expendable. She closes with the enemy at speed, launches torpedoes, and runs before the return fire connects. Small crew, high risk, enormous potential if the torpedoes hit. JFK commanded PT-109. The SAS used them for commando raids. Every navy built them because they were cheap enough to risk and deadly enough to matter.",
      "toughLevel": -1,
      "armourLevel": -2,
      "speedLevel": 1,
      "handlingLevel": 3,
      "mods": {},
