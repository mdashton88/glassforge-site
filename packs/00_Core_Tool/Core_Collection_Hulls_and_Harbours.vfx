{
  "id": "core-hulls-harbours",
  "name": "Core Collection \u2014 Hulls & Harbours",
  "version": "1.0",
  "publisher": "Glassforge Games Ltd.",
  "description": "8 vehicles \u2014 Watercraft from rowboats to ships of the line. Reference implementations from the Savage Worlds core rules covering sail, motor, and oar-powered vessels.",
  "weapons": [],
  "mods": [],
  "specials": [],
  "vehicles": [
    {
      "name": "Rowboat",
      "size": 0,
      "loco": "water_turbo",
      "desc": "Two oars, no motor, unlimited splinters. Dinghies, skiffs, and anything you can row.",
      "notes": "Dinghies, skiffs, ship's boats, tenders, coracles, and anything propelled by oars or poles. She's your silent insertion vehicle \u2014 invisible against a dark shoreline, carrying a small team to wherever they need to be without alerting anyone. Also the thing standing between your players and drowning when the ship goes down. Every nautical campaign needs half a dozen of these available at inconvenient moments.",
      "toughLevel": 1,
      "armourLevel": -1,
      "speedLevel": -3,
      "handlingLevel": -3,
      "woundsLevel": -2,
      "mods": {},
      "weapons": [],
      "specials": [
        "open_top",
        "shallow_draft"
      ],
      "customSpecial": "",
      "passengers": 3,
      "mphOverride": 5
    },
    {
      "name": "Speed Boat",
      "size": 4,
      "loco": "water_turbo",
      "desc": "Outboard motor, fibreglass hull, weekend fun. Ski boats, bass boats, and cigarette racers.",
      "notes": "Ski boats, bass boats, cigarette racers, RIBs (Rigid Inflatable Boats), and every fibreglass hull with an outboard motor. She's the sports car of the water \u2014 fast, agile, and fragile. Drug runners, coast guard pursuit, waterfront chases, and players who need to be somewhere coastal in a hurry. The cigarette boat variant is practically a genre requirement for any 1980s Miami campaign.",
      "toughLevel": 0,
      "armourLevel": -2,
      "speedLevel": 2,
      "handlingLevel": 1,
      "woundsLevel": -2,
      "mods": {},
      "weapons": [],
      "specials": [
        "open_top"
      ],
      "customSpecial": "",
      "passengers": 3,
      "mphOverride": 90
    },
    {
      "name": "Small Yacht",
      "size": 8,
      "loco": "water_turbo",
      "desc": "Comfortable coastal cruiser. Forty feet of fibreglass, teak, and someone else paying the marina fees.",
      "notes": "Beneteau Oceanis, Jeanneau Sun Odyssey, Bavaria Cruiser, and the dozens of 35-45 foot coastal cruisers that fill every marina. She's a location, not a chase vehicle. The party happens here, the deal goes down here, the villain entertains guests on the upper deck while your players infiltrate from the waterline. Comfortable, expensive, and conspicuous \u2014 nobody sails a yacht anonymously.",
      "toughLevel": 0,
      "armourLevel": -1,
      "speedLevel": 0,
      "handlingLevel": 1,
      "mods": {},
      "weapons": [],
      "specials": [
        "enclosed",
        "spacious",
        "long_range"
      ],
      "customSpecial": "",
      "crewLevel": -4,
      "passengers": 9,
      "mphOverride": 35
    },
    {
      "name": "River Patrol Boat",
      "size": 7,
      "loco": "water_turbo",
      "desc": "Shallow draft, heavy weapons, brown-water navy. PBRs, Swift Boats, and their equivalents.",
      "notes": "PBRs (Patrol Boat, River), Swift Boats (PCF), Nasty-class patrol boats, and their equivalents from every riverine conflict. Shallow draft, heavy weapons, brown-water navy. She navigates waterways that would ground larger craft, armed enough to suppress fire from both banks simultaneously. Think Mekong Delta, Colombian rivers, African estuaries \u2014 anywhere the war is fought on water too shallow for real warships. Heavy Armor.",
      "toughLevel": 0,
      "armourLevel": 0,
      "speedLevel": 0,
      "handlingLevel": 1,
      "mods": {},
      "weapons": [
