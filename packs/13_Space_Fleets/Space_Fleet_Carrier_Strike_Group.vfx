{
  "id": "space-fleet-carrier-strike-group",
  "name": "Space Fleets \u2014 Carrier Strike Group",
  "version": "1.0",
  "publisher": "Glassforge Games Ltd.",
  "description": "10 vehicles \u2014 Carrier-based warfare: scramble fighters, launch strikes, and protect the fleet. Built for campaigns where the carrier is home, the fighters are your sword, and losing either means extinction.",
  "weapons": [],
  "mods": [],
  "specials": [],
  "vehicles": [
    {
      "name": "Viper (Light Interceptor)",
      "desc": "Single-seat space superiority fighter launched from a carrier's tubes at crushing acceleration. She's designed for one thing \u2014 killing other fighters \u2014 and she does it with an elegance born of decades of iterative refinement. Thrust vectoring gives her manoeuvrability that borders on the inhuman, and her twin cannons can shred anything she can catch. Her pilots are the best in the fleet. They know it. Everyone else knows it too.",
      "notes": "Space superiority. Carrier-launched. Exceptional manoeuvrability.",
      "size": 5,
      "loco": "space_thruster",
      "toughLevel": -2,
      "armourLevel": -1,
      "speedLevel": 3,
      "handlingLevel": 3,
      "woundsLevel": 0,
      "crewLevel": 0,
      "passengers": 0,
      "mphOverride": 0,
      "mods": {},
      "weapons": [
        {
          "weaponId": "ac_future",
          "mount": "fixed",
          "linked": 1
        }
      ]
    },
    {
      "name": "Raptor (Electronic Warfare)",
      "desc": "Multi-role electronic warfare craft and the fleet's eyes and ears. She carries sensor equipment, ECM suites, and communications relay gear that makes her indispensable for fleet operations. Her crew of two \u2014 pilot and electronic warfare officer \u2014 can jam enemy targeting, spoof missile locks, and coordinate fighter formations. Unarmed and relying on escort fighters for protection.",
      "notes": "ECM/ECCM. Sensor platform. Unarmed \u2014 requires fighter escort.",
      "size": 6,
      "loco": "space_thruster",
      "toughLevel": -1,
      "armourLevel": 0,
      "speedLevel": 2,
      "handlingLevel": 2,
      "woundsLevel": 0,
      "crewLevel": 1,
      "passengers": 0,
      "mphOverride": 0,
      "mods": {},
      "weapons": []
    },
    {
      "name": "Heavy Assault Fighter",
      "desc": "Two-seat strike fighter carrying enough ordnance to threaten capital ships. She's slower than a pure interceptor and relies on fighter cover during her attack run, but the missiles she carries can crack a cruiser's armour belt. Her weapons officer manages targeting solutions while the pilot focuses on keeping them alive long enough to fire. Post-strike survival rate: sixty percent. Nobody talks about the other forty.",
      "notes": "Anti-ship strike role. Two crew. Heavy ordnance. Requires escort.",
      "size": 7,
      "loco": "space_thruster",
      "toughLevel": 0,
      "armourLevel": 0,
      "speedLevel": 2,
      "handlingLevel": 1,
      "woundsLevel": 0,
      "crewLevel": 1,
      "passengers": 0,
      "mphOverride": 0,
      "mods": {},
      "weapons": [
        {
          "weaponId": "ac_future",
          "mount": "fixed",
          "linked": 0
        },
        {
          "weaponId": "missile_med",
          "mount": "fixed",
          "linked": 0
        }
      ]
    },
    {
      "name": "Fleet Carrier",
      "desc": "Combined carrier-battleship and the heart of the fleet. She launches fighters from armoured flight pods, engages capital ships with broadside batteries, and absorbs punishment that would destroy lesser vessels. Her crew of thousands lives, works, and fights in a vessel designed to sustain independent operations indefinitely. When everything else falls, she becomes the last city her people have left.",
      "notes": "Combined carrier/battleship. Hangar capacity for 80+ fighters. Broadside batteries.",
      "size": 22,
      "loco": "space_ftl",
      "toughLevel": 3,
      "armourLevel": 3,
      "speedLevel": -1,
      "handlingLevel": -2,
      "woundsLevel": 0,
      "crewLevel": 10,
      "passengers": 0,
      "mphOverride": 0,
      "mods": {},
      "weapons": [
        {
