        },
        {
          "weaponId": "missile_light",
          "mount": "fixed",
          "linked": 0
        }
      ]
    },
    {
      "name": "Escort Frigate (Carrier Group)",
      "desc": "Fast warship tasked with screening the carrier from torpedo attacks and submarine-style ambushes. She carries enough point-defence to create a wall of flak around the fleet's capital ships, and her speed lets her chase down threats before they reach firing range. Her crew knows their job is to die protecting the carrier, and they've made their peace with it.",
      "notes": "Carrier escort. Excellent point-defence. Anti-torpedo screening.",
      "size": 14,
      "loco": "space_ftl",
      "toughLevel": 0,
      "armourLevel": 0,
      "speedLevel": 1,
      "handlingLevel": 1,
      "woundsLevel": 0,
      "crewLevel": -9,
      "passengers": 0,
      "mphOverride": 0,
