        }
      ]
    },
    {
      "name": "Fleet Tender",
      "desc": "Support vessel carrying fuel, ammunition, food, spare parts, and everything else a fleet needs to keep fighting. She's not glamorous and she'll never make the propaganda posters, but without her the carrier's fighters run dry in three days and the fleet starves in two weeks. Her crew are logistics specialists who can perform miracles with diminishing supplies.",
      "notes": "Fleet supply ship. Fuel and ammunition replenishment. Lightly armed.",
      "size": 16,
      "loco": "space_ftl",
      "toughLevel": 0,
      "armourLevel": 0,
      "speedLevel": -1,
      "handlingLevel": -2,
      "woundsLevel": 0,
      "crewLevel": 80,
      "passengers": 0,
      "mphOverride": 0,
      "mods": {},
      "weapons": [
        {
          "weaponId": "laser_gat",
          "mount": "turret",
