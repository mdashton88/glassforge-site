        {
          "weaponId": "laser_gat",
          "mount": "turret",
          "linked": 0
        }
      ]
    },
    {
      "name": "Refugee Ship",
      "desc": "Civilian liner pressed into service as an evacuation vessel when the homeworlds fell. She was designed for luxury cruises and now carries thousands of survivors in conditions that would shame a cattle barge. Water is rationed, food is synthetic, and the air tastes of too many people in too small a space. But she's alive, and her passengers are alive, and in a fleet of survivors that's enough.",
      "notes": "Civilian vessel. Carries 2000+ refugees. No weapons. Must be protected.",
      "size": 18,
      "loco": "space_ftl",
      "toughLevel": 0,
      "armourLevel": -1,
      "speedLevel": -1,
      "handlingLevel": -2,
      "woundsLevel": 0,
      "crewLevel": 55,
      "passengers": 0,
      "mphOverride": 0,
      "mods": {},
      "weapons": []
    },
    {
      "name": "Mining Ship (Fleet)",
      "desc": "Industrial vessel responsible for extracting the raw materials the fleet needs to manufacture ammunition, repair hull damage, and keep the lights on. She lands on asteroids, chews them apart, and refines the ore in onboard smelters. Without her, the fleet dies of attrition within months. Her crew are former civilians who've become the most strategically important people in the fleet.",
      "notes": "Resource extraction. Critical for fleet sustainability. Unarmed.",
      "size": 14,
      "loco": "space_ftl",
      "toughLevel": 1,
      "armourLevel": 0,
      "speedLevel": -2,
      "handlingLevel": -2,
      "woundsLevel": 0,
      "crewLevel": -9,
      "passengers": 0,
      "mphOverride": 0,
      "mods": {},
      "weapons": []
    },
    {
      "name": "Stealth Assault Ship",
      "desc": "Black-ops vessel designed for covert strikes behind enemy lines. She carries a company of marines, a small hangar bay for two fighters, and enough stealth technology to approach an enemy fleet undetected. Her missions are one-way until the fleet catches up \u2014 she goes in quiet, hits hard, and then holds position until relieved or destroyed.",
      "notes": "Stealth. Marine complement. Small hangar. Behind-enemy-lines operations.",
      "size": 12,
      "loco": "space_ftl",
      "toughLevel": 0,
      "armourLevel": 1,
      "speedLevel": 1,
      "handlingLevel": 0,
      "woundsLevel": 0,
      "crewLevel": -11,
      "passengers": 0,
