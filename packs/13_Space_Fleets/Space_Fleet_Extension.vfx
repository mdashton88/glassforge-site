  "mods":[
    {
      "id":"deflector_shields",
      "name":"Deflector Shields",
      "cat":"Space Defence",
      "max":3,
      "mods":2,
      "desc":"Energy shield that absorbs incoming damage. Each level provides +4 Toughness against energy weapons only. Shields regenerate at start of each round if not hit."
    },
    {
      "id":"cloaking_device",
      "name":"Cloaking Device",
      "cat":"Space Systems",
      "max":1,
      "mods":3,
      "desc":"Renders the vessel invisible to sensors and the naked eye. Ship cannot fire weapons while cloaked. Activating or deactivating takes one action."
    },
    {
      "id":"hangar_bay",
      "name":"Hangar Bay",
      "cat":"Space Systems",
      "max":4,
      "mods":2,
      "desc":"Internal hangar capable of launching and recovering small craft. Each level supports 12 fighters or 6 shuttles. Includes launch tubes and recovery systems."
    },
    {
      "id":"boarding_ramps",
      "name":"Boarding Ramps",
      "cat":"Space Systems",
      "max":2,
      "mods":1,
      "desc":"Armoured assault ramps and breaching equipment for boarding actions. Each level supports one boarding action per round with a squad of troops."
    },
    {
      "id":"self_repair",
      "name":"Self-Repair Systems",
      "cat":"Space Defence",
      "max":3,
      "mods":2,
      "desc":"Regenerative hull systems — biological, nanite, or automated. Makes a free natural healing roll each round. Bioship: automatic. Mechanical: requires crew action."
    },
    {
      "id":"ramming_prow",
      "name":"Ramming Prow",
      "cat":"Space Offence",
      "max":1,
      "mods":2,
      "desc":"Reinforced bow designed for ramming attacks. Ram damage: vessel's Size × d6, AP equal to half Size. Ramming vessel takes half damage."
    },
    {
      "id":"sensor_suite",
      "name":"Enhanced Sensor Suite",
      "cat":"Space Systems",
      "max":2,
      "mods":1,
      "desc":"Advanced detection equipment. Each level grants +2 to Notice rolls for detecting vessels, scanning targets, and navigating hazards."
    },
    {
      "id":"ecm_suite",
      "name":"ECM Suite",
      "cat":"Space Systems",
      "max":2,
      "mods":1,
      "desc":"Electronic countermeasures that jam targeting systems and spoof missile locks. Each level imposes −2 to enemy Shooting rolls targeting this vessel."
    },
    {
      "id":"expanded_cargo",
      "name":"Expanded Cargo Hold",
      "cat":"Space Systems",
      "max":4,
      "mods":1,
      "desc":"Enlarged cargo capacity. Each level doubles base cargo tonnage for the vessel's size. Reduces available crew space proportionally."
    },
    {
      "id":"biosphere_dome",
      "name":"Biosphere Dome",
      "cat":"Space Habitat",
      "max":4,
      "mods":3,
      "desc":"Transparent dome enclosing a self-sustaining ecosystem. Each level supports 500 residents and provides food production. Fragile — AP 0 against the dome itself."
    },
    {
      "id":"rotating_section",
      "name":"Rotating Habitat Section",
      "cat":"Space Habitat",
      "max":2,
      "mods":2,
      "desc":"Centrifugal gravity section for crew comfort and long-term habitation. Each level supports comfortable living for 200 crew. Reduces long-voyage Fatigue."
    },
    {
      "id":"siege_mode",
      "name":"Siege Mode Stabilisers",
      "cat":"Space Offence",
      "max":1,
      "mods":2,
      "desc":"Deploys stabilisation pylons and diverts power to weapons. While deployed: Speed 0, cannot move, all weapon damage increased by one die type."
    },
    {
      "id":"warp_drive",
      "name":"Warp/Jump Drive",
      "cat":"Space Systems",
      "max":1,
      "mods":2,
      "desc":"FTL drive system for interstellar travel. Narrative travel between star systems. Specific mechanics vary by setting — warp, jump, fold, or slip."
    },
    {
      "id":"escape_pods",
      "name":"Escape Pods",
      "cat":"Space Systems",
      "max":1,
      "mods":1,
      "desc":"Emergency evacuation pods for crew survival. Sufficient pods for full crew complement. Auto-launch on critical damage if systems are functional."
    },
    {
      "id":"point_defence_net",
      "name":"Point Defence Network",
      "cat":"Space Defence",
      "max":2,
      "mods":2,
      "desc":"Coordinated automated defensive fire. Each level allows one free Shooting roll per round against incoming torpedoes, missiles, or fighters at no multi-action penalty."
    }
  ],
  "specials":[
    {
      "id":"carrier_ops",
      "name":"Carrier Operations",
      "cat":"Space",
      "desc":"Vessel can launch and recover fighters. May launch or recover 6 fighters per round. Launched fighters act on the carrier's initiative card."
    },
    {
      "id":"regeneration",
      "name":"Regeneration",
      "cat":"Space (Biological)",
      "desc":"Living vessel heals damage naturally. Makes a Vigour roll at the start of each round — success removes one Wound. Does not apply to Critical Hits."
    },
    {
      "id":"swarm_tactics",
      "name":"Swarm Tactics",
      "cat":"Space",
      "desc":"When 3+ vessels of this type act together, each gains +1 to Shooting rolls. At 6+, the bonus increases to +2. Represents coordinated attack patterns."
    },
    {
      "id":"expendable",
      "name":"Expendable",
      "cat":"Space",
      "desc":"Vessel has no ejection system, escape pods, or self-destruct. Crew casualties on destruction are total. Reduces cost by 25%."
    },
    {
      "id":"unreliable",
      "name":"Unreliable Systems",
      "cat":"Space",
      "desc":"Roll d6 at the start of each encounter. On a 1, one randomly-determined system has failed: weapons (1-2), engines (3-4), or shields (5-6). Repair requires a Repair roll at −2."
    },
    {
      "id":"psychic_crew",
      "name":"Psychic Crew",
      "cat":"Space (Exotic)",
      "desc":"Vessel is crewed by psychically gifted beings. Can use psionic weapons. Crew can sense hostile intent at range (Notice +2 vs ambush). Vulnerable to psychic attack."
    },
    {
      "id":"siege_platform",
      "name":"Siege Platform",
      "cat":"Space",
      "desc":"Vessel can enter siege mode (one action). While in siege mode: Speed 0, Handling −4, but all weapon ranges doubled and damage increased by +2 per die."
    },
    {
      "id":"stealth_systems",
      "name":"Stealth Systems",
      "cat":"Space",
      "desc":"Low-emission design and sensor-absorbing hull. −4 to enemy Notice rolls to detect this vessel. Cannot fire weapons without breaking stealth."
    },
    {
      "id":"living_ship",
      "name":"Living Ship",
      "cat":"Space (Biological)",
      "desc":"Vessel is a living organism. Uses Vigour instead of Toughness for damage resistance. Heals naturally. Immune to ion/EMP weapons. Vulnerable to poison/disease."
    },
    {
      "id":"atmospheric_entry",
      "name":"Atmospheric Entry",
      "cat":"Space",
      "desc":"Vessel can enter and exit planetary atmospheres. Heat shielding and aerodynamic profile allow controlled descent. Can operate in atmosphere at half space speed."
    },
    {
      "id":"ramshackle",
      "name":"Ramshackle Construction",
      "cat":"Space",
      "desc":"Vessel is built from salvaged and improvised components. −2 Toughness, but on a Critical Hit, roll d6: on a 5-6, the damage hits a non-essential system instead."
    },
    {
      "id":"ancient_tech",
      "name":"Ancient Technology",
      "cat":"Space (Exotic)",
      "desc":"Vessel uses technology from a long-dead civilisation. Weapons ignore conventional armour. Self-repairing hull. However, if disabled, no living being can repair her."
    }
  ],
  "vehicles":[]
}