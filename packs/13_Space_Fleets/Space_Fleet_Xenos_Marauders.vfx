        {
          "weaponId": "ac_heavy",
          "mount": "turret",
          "linked": 0
        }
      ]
    },
    {
      "name": "Scrap Fighter",
      "desc": "Single-seat attack craft assembled from whatever was lying around the hangar floor when the pilot wandered in. Wings are optional. Cockpit pressurisation is aspirational. Weapons are whatever the pilot could carry aboard. She flies through a combination of engineering, prayer, and the collective psychic belief of her species that she should fly. Against all logic, she usually does.",
      "notes": "Unreliable. Roll a d6 at the start of each encounter \u2014 on a 1, one system has failed.",
      "size": 4,
      "loco": "space_thruster",
      "toughLevel": -1,
      "armourLevel": -1,
      "speedLevel": 2,
      "handlingLevel": 1,
      "woundsLevel": 0,
      "crewLevel": 0,
      "passengers": 0,
      "mphOverride": 0,
      "mods": {},
      "weapons": [
        {
          "weaponId": "ac_heavy",
          "mount": "fixed",
          "linked": 0
        },
        {
          "weaponId": "rocket_light",
          "mount": "fixed",
          "linked": 0
        }
      ]
    },
    {
      "name": "Wraithbone Escort",
      "desc": "Elegant vessel grown rather than built, her hull a single piece of psychically-shaped crystal that shifts and flexes in response to her crew's thoughts. Faster than anything in human space, more manoeuvrable than physics should allow, and armed with weapons that fire focused psychic energy. Her crew numbers in the dozens where human ships of similar firepower need thousands.",
      "notes": "Eldar archetype. Extremely fast and agile. Small crew. Fragile if hit.",
      "size": 12,
      "loco": "space_ftl",
      "toughLevel": -1,
      "armourLevel": -1,
      "speedLevel": 3,
      "handlingLevel": 2,
      "woundsLevel": 0,
      "crewLevel": -13,
      "passengers": 0,
      "mphOverride": 0,
      "mods": {},
      "weapons": [
        {
          "weaponId": "psionic_lance",
          "mount": "turret",
          "linked": 0
        },
        {
          "weaponId": "laser_med",
          "mount": "turret",
          "linked": 0
        }
      ]
    },
    {
      "name": "Wraithbone Cruiser",
      "desc": "Capital ship of the elder race, a sweeping organic form that moves through space like a hunting bird. Pulse lances reach out across impossible distances with surgical precision, and her speed lets her dictate the terms of every engagement. She never fights fair \u2014 she kills from range and vanishes before the enemy can respond. Her crew pity the younger races. That pity does not extend to mercy.",
      "notes": "Eldar archetype. Hit-and-run specialist. Cannot sustain a broadside exchange.",
      "size": 18,
      "loco": "space_ftl",
      "toughLevel": 0,
      "armourLevel": 0,
      "speedLevel": 2,
      "handlingLevel": 1,
      "woundsLevel": 0,
      "crewLevel": 55,
      "passengers": 0,
      "mphOverride": 0,
      "mods": {},
      "weapons": [
        {
          "weaponId": "psionic_lance",
          "mount": "turret",
          "linked": 0
        },
        {
          "weaponId": "psionic_lance",
          "mount": "turret",
          "linked": 0
        },
        {
          "weaponId": "laser_med",
          "mount": "turret",
          "linked": 0
        }
      ]
    },
    {
      "name": "Drone Swarm Carrier",
      "desc": "Hive-mind vessel that does not carry fighters so much as extrude them. Automated fabrication bays produce expendable attack drones at a rate that overwhelms point-defence systems through sheer volume. The carrier herself is lightly armed, relying on her swarm for both offence and defence. Destroying the drones is futile \u2014 she builds replacements faster than you can kill them.",
      "notes": "Launches drone swarms. Light direct armament. Destroying drones is temporary.",
      "size": 16,
      "loco": "space_ftl",
      "toughLevel": 0,
      "armourLevel": 0,
      "speedLevel": 0,
      "handlingLevel": -1,
      "woundsLevel": 0,
      "crewLevel": 80,
      "passengers": 0,
      "mphOverride": 0,
      "mods": {},
      "weapons": [
        {
          "weaponId": "ion_disruptor",
          "mount": "turret",
          "linked": 0
        },
        {
          "weaponId": "flak_battery",
          "mount": "turret",
          "linked": 0
        }
      ]
    },
    {
      "name": "Bio-Ship (Escort)",
      "desc": "Living vessel spawned from the gene-pools of a hive fleet. She has no crew in any conventional sense \u2014 the entire ship is a single organism with distributed neural tissue and bio-weapon organs that spit acid, spores, or plasma-analogue across the void. She heals damage that would cripple a conventional vessel, and her weapons grow back within hours of being destroyed.",
      "notes": "Tyranid archetype. Living ship. Regenerates 1 Wound per round. Bio-weapons.",
      "size": 12,
      "loco": "space_ftl",
      "toughLevel": 1,
      "armourLevel": 0,
      "speedLevel": 1,
      "handlingLevel": 0,
      "woundsLevel": 0,
      "crewLevel": -13,
      "passengers": 0,
      "mphOverride": 0,
      "mods": {},
      "weapons": [
        {
          "weaponId": "bio_plasma",
          "mount": "fixed",
          "linked": 0
        },
        {
          "weaponId": "acid_spray",
          "mount": "turret",
          "linked": 0
        }
      ]
    },
    {
      "name": "Bio-Ship (Cruiser)",
      "desc": "Vast living organism the size of a conventional cruiser, her hull a mass of chitin and bone-armour that absorbs kinetic impacts and regenerates tissue around energy weapon burns. Bio-plasma organs along her flanks spit burning matter across tens of thousands of kilometres, and her interior swarms with organisms adapted for boarding actions. She does not think. She hungers.",
      "notes": "Tyranid archetype. Regenerates. Spawns boarding organisms. Massive bio-weapons.",
      "size": 20,
      "loco": "space_ftl",
      "toughLevel": 2,
      "armourLevel": 2,
      "speedLevel": 0,
      "handlingLevel": -1,
      "woundsLevel": 0,
      "crewLevel": 180,
      "passengers": 0,
      "mphOverride": 0,
