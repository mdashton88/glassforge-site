{
  "id": "space-fleet-xenos-marauders",
  "name": "Space Fleets \u2014 Xenos Marauders",
  "version": "1.0",
  "publisher": "DiceForge Studios Ltd.",
  "description": "10 vehicles \u2014 Alien war fleets of wildly different design philosophies. Ramshackle hulks held together by belief, elegant wraithbone vessels that move like living things, and bioships grown from the gene-soup of consumed worlds.",
  "weapons": [],
  "mods": [],
  "specials": [],
  "vehicles": [
    {
      "name": "Brute Ram Ship",
      "desc": "Massive chunk of asteroid with engines bolted to one end and guns welded to every available surface by greenskin mechanics who operate on the principle that if you hit something hard enough, engineering doesn't matter. Navigation is approximate. Targeting is enthusiastic rather than accurate. But she masses enough to simply crush anything she rams, and her crew considers structural failure to be someone else's problem.",
      "notes": "Ramshackle construction. Unreliable but devastating on impact. Ork archetype.",
      "size": 16,
      "loco": "space_ftl",
      "toughLevel": 2,
      "armourLevel": 1,
      "speedLevel": -1,
      "handlingLevel": -2,
      "woundsLevel": 0,
      "crewLevel": 80,
      "passengers": 0,
      "mphOverride": 0,
      "mods": {},
