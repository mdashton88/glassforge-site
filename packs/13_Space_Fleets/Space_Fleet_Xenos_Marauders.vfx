        {
          "weaponId": "spore_mine",
          "mount": "turret",
          "linked": 0
        }
      ]
    },
    {
      "name": "Pirate Raider (Alien)",
      "desc": "Dark-hulled vessel crewed by alien corsairs who raid for sport as much as profit. She carries cloaking technology that renders her nearly invisible to sensors until she's close enough for her weapons to be unavoidable. Prize crews are trained to disable rather than destroy \u2014 cargo is profitable, but captives are more so.",
      "notes": "Dark Eldar archetype. Stealth systems. Prefers capture over destruction.",
      "size": 10,
      "loco": "space_ftl",
      "toughLevel": -1,
      "armourLevel": 0,
      "speedLevel": 2,
      "handlingLevel": 2,
      "woundsLevel": 0,
      "crewLevel": 0,
      "passengers": 0,
      "mphOverride": 0,
      "mods": {},
      "weapons": [
        {
          "weaponId": "psionic_lance",
          "mount": "turret",
          "linked": 0
        },
        {
          "weaponId": "ion_disruptor",
          "mount": "turret",
          "linked": 0
        }
      ]
    },
    {
      "name": "Ancient Tomb Ship",
      "desc": "Vessel of an ancient machine-race that predates biological civilisation by millions of years. She lay dormant beneath a dead world until something woke her, and now she cuts through modern fleets with weapons that ignore shields, phase through armour, and unmake matter at the molecular level. Her crew are metal skeletons animated by technology indistinguishable from sorcery.",
      "notes": "Necron archetype. Phase weapons ignore armour. Self-repairing. Terrifying.",
      "size": 22,
      "loco": "space_ftl",
      "toughLevel": 3,
      "armourLevel": 3,
      "speedLevel": -1,
      "handlingLevel": -1,
      "woundsLevel": 0,
      "crewLevel": 10,
      "passengers": 0,
      "mphOverride": 0,
