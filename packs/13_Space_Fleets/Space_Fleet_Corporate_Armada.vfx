          "linked": 1
        }
      ]
    },
    {
      "name": "Dreadnought (Siege)",
      "desc": "Dedicated structure-killer built around a siege cannon capable of reducing orbital stations to scrap. She enters siege mode by deploying stabilisation pylons and diverting all power to the main weapon, rendering her immobile but devastating. In fleet engagements she's a liability \u2014 slow, expensive, and vulnerable. Against fixed installations, she's the most cost-effective weapon ever designed.",
      "notes": "Siege specialist. Immobile when firing main weapon. Station-killer.",
      "size": 24,
      "loco": "space_ftl",
      "toughLevel": 3,
      "armourLevel": 3,
      "speedLevel": -3,
      "handlingLevel": -4,
      "woundsLevel": 0,
      "crewLevel": 140,
      "passengers": 0,
      "mphOverride": 0,
      "mods": {},
      "weapons": [
        {
          "weaponId": "cannon_superheavy",
          "mount": "fixed",
          "linked": 0
