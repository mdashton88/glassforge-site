          "linked": 0
        }
      ]
    },
    {
      "name": "Battleship (Corporate)",
      "desc": "Heavy capital ship representing serious corporate investment. She's the big stick that backs up diplomatic negotiations, protects strategic assets, and occasionally reduces rival corporation stations to debris when the board of directors authorises hostile takeover in its most literal sense. Her captain answers to shareholders, and her kill record is itemised in quarterly reports.",
      "notes": "Corporate capital ship. Expensive but decisive. Heavy armour and weapons.",
      "size": 20,
      "loco": "space_ftl",
      "toughLevel": 2,
      "armourLevel": 2,
      "speedLevel": -1,
      "handlingLevel": -2,
      "woundsLevel": 0,
      "crewLevel": 180,
      "passengers": 0,
