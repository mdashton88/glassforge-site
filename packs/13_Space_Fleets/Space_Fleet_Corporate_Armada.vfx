        {
          "weaponId": "laser_gat",
          "mount": "turret",
          "linked": 1
        }
      ]
    },
    {
      "name": "Titan",
      "desc": "The most expensive single object ever constructed by corporate humanity. Kilometres long, crewed by thousands, and carrying a doomsday weapon capable of destroying capital ships in a single discharge. She is simultaneously a corporation's greatest asset and its greatest liability \u2014 her destruction would bankrupt most organisations, and her deployment is authorised only by CEO vote. When she jumps into a system, the war is already decided.",
      "notes": "Supercapital. Doomsday weapon. Corporation-ending loss if destroyed.",
      "size": 30,
      "loco": "space_ftl",
      "toughLevel": 5,
      "armourLevel": 5,
      "speedLevel": -3,
      "handlingLevel": -5,
      "woundsLevel": 0,
      "crewLevel": -350,
      "passengers": 0,
      "mphOverride": 0,
      "mods": {},
