{
  "id": "space-fleet-corporate-armada",
  "name": "Space Fleets \u2014 Corporate Armada",
  "version": "1.0",
  "publisher": "Glassforge Games Ltd.",
  "description": "10 vehicles \u2014 Corporate warfare in deep space, where mega-corporations field private navies and the line between commerce and conquest is measured in profit margins. From mining frigates to fleet-killing titans.",
  "weapons": [],
  "mods": [],
  "specials": [],
  "vehicles": [
    {
      "name": "Tackle Frigate",
      "desc": "Fast, disposable frigate designed for one job: get close to enemy ships, disrupt their FTL drives, and hold them in place until the fleet arrives to finish them off. Her crew knows they're bait. The corporation pays hazard bonuses and maintains a generous life insurance policy. Both facts are cold comfort when a battleship's tracking computer locks onto your hull.",
      "notes": "Electronic warfare. FTL disruption. Expendable but critical to fleet doctrine.",
      "size": 6,
      "loco": "space_ftl",
      "toughLevel": -2,
      "armourLevel": -1,
      "speedLevel": 3,
      "handlingLevel": 3,
      "woundsLevel": 0,
      "crewLevel": 0,
      "passengers": 0,
      "mphOverride": 0,
      "mods": {},
