        {
          "weaponId": "ion_disruptor",
          "mount": "turret",
          "linked": 0
        }
      ]
    },
    {
      "name": "Combat Cruiser",
      "desc": "Versatile warship that forms the core of corporate fleet doctrines. She's the ship accountants love \u2014 cost-effective to build, efficient to crew, and capable of engaging targets well above her weight class when properly supported. Fleet commanders stack them in formations of fifty or more, creating walls of overlapping fire that grind enemy fleets into insurance claims.",
      "notes": "Fleet doctrine ship. Best in large numbers. Cost-effective combat platform.",
      "size": 14,
      "loco": "space_ftl",
      "toughLevel": 0,
      "armourLevel": 1,
      "speedLevel": 0,
      "handlingLevel": 0,
      "woundsLevel": 0,
      "crewLevel": -9,
      "passengers": 0,
      "mphOverride": 0,
