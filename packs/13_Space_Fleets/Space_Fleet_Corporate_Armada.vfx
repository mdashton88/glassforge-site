        },
        {
          "weaponId": "torpedo_heavy",
          "mount": "fixed",
          "linked": 0
        }
      ]
    },
    {
      "name": "Mining Barge",
      "desc": "Industrial vessel designed to strip-mine asteroid belts and process ore in flight. Her massive laser arrays cut through rock like butter, and her hold can swallow thousands of tonnes of raw material. She's the foundation of the corporate economy \u2014 every warship, every station, every bullet started life as rock floating in the void until a mining barge chewed it up and spat out refined materials.",
      "notes": "Industrial. Mining lasers can be used as weapons in desperation. Slow, unarmed.",
      "size": 12,
      "loco": "space_ftl",
      "toughLevel": 1,
      "armourLevel": 0,
      "speedLevel": -2,
      "handlingLevel": -2,
      "woundsLevel": 0,
      "crewLevel": -13,
      "passengers": 0,
      "mphOverride": 0,
      "mods": {},
      "weapons": []
    },
    {
      "name": "Industrial Hauler",
      "desc": "Massive cargo vessel that moves the raw materials of interstellar commerce between systems. She's the lorry of the spacelanes \u2014 unglamorous, essential, and a favourite target of pirates. Corporate hauler convoys are often escorted by combat fleets, and the cargo they carry is insured for more than most warships cost. Her crew is small, her hold is vast, and her schedule is unforgiving.",
      "notes": "Enormous cargo capacity. Slow. High-value target.",
      "size": 18,
      "loco": "space_ftl",
      "toughLevel": 0,
      "armourLevel": 0,
      "speedLevel": -2,
      "handlingLevel": -3,
      "woundsLevel": 0,
      "crewLevel": 55,
      "passengers": 0,
      "mphOverride": 0,
      "mods": {},
      "weapons": [
        {
          "weaponId": "laser_gat",
          "mount": "turret",
          "linked": 0
        }
      ]
    },
    {
      "name": "Logistics Cruiser",
      "desc": "Support vessel that keeps a fleet fighting by projecting repair nanites and energy transfers to damaged allies at range. She carries no offensive weapons \u2014 her entire design is built around keeping other ships alive. In fleet doctrine she's the most valuable target on the field, and destroying the enemy's logistics chain is often the difference between victory and a war of attrition nobody can afford.",
      "notes": "Fleet support. Remote repair capability. Priority target in fleet actions.",
      "size": 12,
      "loco": "space_ftl",
      "toughLevel": 0,
      "armourLevel": 1,
      "speedLevel": 0,
      "handlingLevel": 0,
      "woundsLevel": 0,
      "crewLevel": -11,
      "passengers": 0,
      "mphOverride": 0,
      "mods": {},
      "weapons": []
    },
    {
      "name": "Stealth Bomber (Corporate)",
      "desc": "Cloaked torpedo delivery platform operated by corporate black ops divisions. She drops out of nothing, delivers a volley of ship-killing torpedoes, and vanishes before the target's point-defence can acquire her. Officially, she doesn't exist. Unofficially, every major corporation operates squadrons of them, and their kills are attributed to piracy, mechanical failure, or navigational error.",
      "notes": "Cloaking device. Torpedo-focused. Glass cannon \u2014 dies instantly if caught.",
      "size": 7,
      "loco": "space_ftl",
      "toughLevel": -2,
      "armourLevel": -1,
      "speedLevel": 2,
      "handlingLevel": 2,
      "woundsLevel": 0,
      "crewLevel": 0,
      "passengers": 0,
      "mphOverride": 0,
      "mods": {},
